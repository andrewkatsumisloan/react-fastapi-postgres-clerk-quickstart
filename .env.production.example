# Copy this file to .env.production and pass it to Compose with:
# docker compose --env-file .env.production -f docker-compose.prod.yml up --build

# Browser-visible Clerk key used at Vite build time.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key

# Optional. Leave blank to use same-origin /api through nginx in docker-compose.prod.yml.
VITE_API_BASE_URL=

# External production Postgres database. The production Compose file does not run Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk backend settings.
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# Optional. Set if your JWT template includes an audience.
CLERK_AUDIENCE=

# Optional if clients call the API directly from another origin.
CORS_ALLOW_ORIGINS=https://your-app.example.com
