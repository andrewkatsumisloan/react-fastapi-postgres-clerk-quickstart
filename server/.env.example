# Core settings
DEBUG=false
PROJECT_NAME="Test"
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database connection
# Option 1: For local PostgreSQL container (default in Docker setup)
# These values are set in docker-compose.yml, you don't need to set them here
# when running with docker-compose
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=appdb

# Option 2: For AWS RDS or external PostgreSQL
# Uncomment and set this to use a specific PostgreSQL instance
# DATABASE_URL=postgresql://user:password@your-rds-hostname.rds.amazonaws.com:5432/dbname

# Clerk Authentication
# Issuer is your Clerk frontend API URL (e.g. https://<instance>.clerk.accounts.dev)
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
# Backwards-compatible alias accepted by config:
# CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
# Optional: set if you use a JWT template with a specific audience
CLERK_AUDIENCE=your-api-audience
CLERK_SECRET_KEY=your_clerk_secret_key

# Stripe Payments (optional opt-in feature)
# Leave these blank to keep the payments UI disabled.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_DEFAULT_PRICE_ID=price_your_default_price_id
STRIPE_PAYMENT_MODE=payment
STRIPE_FRONTEND_URL=http://localhost:3000
# Optional overrides. Defaults redirect to STRIPE_FRONTEND_URL with checkout status.
# STRIPE_SUCCESS_URL=http://localhost:3000/?checkout=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:3000/?checkout=canceled
STRIPE_AUTOMATIC_TAX_ENABLED=false
